import java.util.*;
import java.util.Random;

// MAKING A PASSWORD GENERATOR WHICH GENERATES A STRONG PASSWORD CONSISTING OF UPPER AND LOWER ALPHABETS, NUMBERS AND SYMBOLS

public class Main
{
	public static void main(String[] args) {
	    Scanner sc = new Scanner(System.in);
	    Random random = new Random();
	    
	    String upper = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
	    String lower = "abcdefghijklmnopqrstuvwxyz";
	    String nums = "1234567890";
	    String symbols = "!@#$%^&*";
	    
	    String charlist = upper + lower + nums + symbols;
	    
	    System.out.println("Please Enter the Length of Password: ");
	    int length = sc.nextInt();
	    
	    String password = " ";
	    
	    for(int i = 0; i<length; i++){
	        int index = random.nextInt(charlist.length());
	        password += charlist.charAt(index);
	    }
	    
	    System.out.println("PASSWORD GENERATED SUCCESSFULLY");
	    System.out.println("GENERATED PASSWORD: " + password);
	    
	}
}
